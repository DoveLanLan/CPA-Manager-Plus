COMPOSE_PROJECT_NAME=cpa-manager-plus
CPA_MANAGER_PLUS_IMAGE=ghcr.io/dovelanlan/cpa-manager-plus:main
TZ=Asia/Shanghai

GATEWAY_NETWORK=vps-gateway
TAILSCALE_BIND_IP=100.67.99.9
TAILSCALE_CPA_MANAGER_PLUS_PORT=18318

CPA_MANAGER_PLUS_DATA_DIR=/opt/cliproxyapi/data/cpa-manager
CPA_UPSTREAM_URL=http://cli-proxy-api:8317
CPA_MANAGEMENT_KEY_FILE=/data/cpa-management-key.txt
CPA_MANAGER_ADMIN_KEY_FILE=/data/admin-key.txt
CPA_MANAGER_DATA_KEY_PATH=/data/data.key

USAGE_COLLECTOR_MODE=auto
USAGE_RESP_QUEUE=usage
USAGE_RESP_POP_SIDE=right
USAGE_BATCH_SIZE=100
USAGE_POLL_INTERVAL_MS=500
USAGE_QUERY_LIMIT=50000
USAGE_CORS_ORIGINS=*
